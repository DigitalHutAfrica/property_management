<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="maintenance_request_notification_mail_template" model="mail.template">
            <field name="name">Rental Management: Maintenance Request Notification</field>
            <field name="model_id" ref="maintenance.model_maintenance_request"/>
            <field name="subject">Maintenance Request Submitted</field>
            <field name="email_from">{{ object.tenant_id.email }}</field>
            <field name="email_to">{{ object.property_id.parent_property_id.maintenance_incharge_id.email }}</field>
            <!--            <field name="partner_to">{{ object.property_id.parent_property_id.maintenance_incharge_id.id }}-->
            <!--            </field>-->
            <field name="body_html" type="html">
                <table style="width:100%">
                    <br/>
                    <tr>
                        <td>
                            Dear&#160;<span
                                t-field="object.property_id.parent_property_id.maintenance_incharge_id.name"
                                t-if="object.property_id.parent_property_id.maintenance_incharge_id"/>,
                            <br/>
                            <br/>
                            <span>
                                Greetings!
                            </span>
                        </td>
                    </tr>
                </table>
                <br/>
                <span>
                    This is to notify you that a maintenance request for contract -
                    <strong>
                        <span t-field="object.contract_id"/>
                    </strong>
                    has been generated.
                </span>
                <br/>
                <br/>
                <span>
                    <table class="table-responsive w-75">
                        <t t-if="object.name">
                            <tr>
                                <td>
                                    <strong>
                                        Issue
                                    </strong>
                                </td>
                                <td>:</td>
                                <td>
                                    <t t-out="object.name"/>
                                </td>
                            </tr>
                        </t>
                        <t t-if="object.property_id">
                            <tr>
                                <td>
                                    <strong>
                                        Property
                                    </strong>
                                </td>
                                <td>:</td>
                                <td>
                                    <span t-field="object.property_id"/>
                                </td>
                            </tr>
                        </t>
                        <t t-if="object.tenant_id">
                            <tr>
                                <td>
                                    <strong>
                                        Tenant
                                    </strong>
                                </td>
                                <td>:</td>
                                <td>
                                    <t t-out="object.tenant_id.name"/>
                                </td>
                            </tr>
                        </t>
                        <t t-if="object.description">
                            <tr>
                                <td>
                                    <strong>
                                        Issue Description
                                    </strong>
                                </td>
                                <td>:</td>
                                <td>
                                    <t t-out="object.description"/>
                                </td>
                            </tr>
                        </t>
                    </table>
                </span>
                <br/>
                <div>
                    Best regards,
                </div>
                <div>
                    <strong>
                        <t t-out="object.company_id.name"/>
                    </strong>
                </div>
                <hr/>
                <span>
                    <h6>
                        <t t-out="object.company_id.name"/>
                    </h6>
                    <t t-out="object.company_id.phone"/>
                    <br/>
                    <t t-out="object.company_id.email"/>
                    <br/>
                    <t t-out="object.company_id.website"/>
                </span>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>