<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="property_sequence" model="ir.sequence">
            <field name="name">Property Sequence Number</field>
            <field name="code">property.details</field>
            <field name="active">TRUE</field>
            <field name="prefix">PI/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="utility_bill_sequence" model="ir.sequence">
            <field name="name">Utility Bill Sequence Number</field>
            <field name="code">utility.bill</field>
            <field name="active">TRUE</field>
            <field name="prefix">UTILITY/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="tenancy_sequence_new" model="ir.sequence">
            <field name="name">Tenancy Sequence Number</field>
            <field name="code">tenancy.details</field>
            <field name="active">TRUE</field>
            <field name="prefix">C/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="sold_sequence" model="ir.sequence">
            <field name="name">Sold Sequence Number</field>
            <field name="code">property.vendor</field>
            <field name="active">TRUE</field>
            <field name="prefix">PS/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="handover_sequence" model="ir.sequence">
            <field name="name">Tenancy Sequence Number</field>
            <field name="code">handover.property</field>
            <field name="active">TRUE</field>
            <field name="prefix">HO</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>