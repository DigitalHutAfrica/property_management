<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_utility_bill" model="report.paperformat">
        <field name="name">Utility Bill</field>
        <field name="default" eval="True"/>
        <field name="format">A5</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="disable_shrinking" eval="False"/>
        <field name="dpi">110</field>
    </record>

    <record id="action_utility_bill_report" model="ir.actions.report">
        <field name="name">Utility Bill</field>
        <field name="model">utility.bill</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">property_management.report_utility_bill_tmpl</field>
        <field name="report_file">property_management.report_utility_bill_tmpl</field>
        <field name="print_report_name">'Utility Bill - %s' % (object.dn_no)</field>
        <field name="binding_model_id" ref="model_utility_bill"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_utility_bill"/>
    </record>
</odoo>
