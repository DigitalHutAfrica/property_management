<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="parent_property_form_view" model="ir.ui.view">
            <field name="name">parent.property.form.view</field>
            <field name="model">parent.property</field>
            <field name="arch" type="xml">
                <form string="Property">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button"
                                    type="object"
                                    name="action_properties_parent"
                                    icon="fa-home">
                                <field name="property_count"
                                       string='Properties'
                                       widget="statinfo"/>
                            </button>
                        </div>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <div class="oe_title mb24">
                            <h1>
                                <field class="text-break" name="name" required="1"
                                       default_focus="1"
                                       placeholder="e.g. Silver Height"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="type" widget="radio" options="{'horizontal':True}"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <span class="o_form_label o_td_label" name="address_name">
                                    <b>Address</b>
                                </span>
                                <div class="o_address_format">
                                    <field name="street" placeholder="Street..." class="o_address_street"/>
                                    <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                    <field name="city_id" placeholder="City" class="o_address_city"/>
                                    <field name="state_id" class="o_address_state" placeholder="State"
                                           options="{'no_open': True, 'no_quick_create': True}"/>
                                    <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                    <field name="country_id" placeholder="Country" class="o_address_country"
                                           options="{'no_open': True, 'no_quick_create': True}"/>
                                </div>
                            </group>
                            <group>
                                <field name="landlord_id" required="1"
                                       options="{'no_quick_create':True,'no_create_edit':True}"/>
                                <field name="website"/>
                                <field name="plot_no" invisible="1"/>
                                <field name="company_id"/>
                                <field name="maintenance_incharge_id" domain="[('is_maintenance_team', '=', True)]"/>
                            </group>
                        </group>
                        <group string="Residential Details" invisible="type != 'residential'">
                            <group>
                                <field name="residence_type" widget="radio"/>
                            </group>
                            <group>
                                <field name="total_floor" invisible="1"/>
                                <field name="towers"/>
                                <field name="no_of_towers"/>
                            </group>
                        </group>
                        <group string="Industrial Details" invisible="type != 'industrial'">
                            <group>
                                <field name="industry_location" widget="radio"/>
                            </group>
                        </group>
                        <group string="Commercial Details" invisible="type != 'commercial'">
                            <group>
                                <field name="commercial_type" widget="radio"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="utility_rate" string="Utility Rate">
                                <field name="utility_rate_ids">
                                    <list editable="bottom">
                                        <field name="meter_type_id"/>
                                        <field name="rate"/>
                                        <field name="currency_id"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Nearby Connectivity" name="nearby_connectivity">
                                <h3 style="text-align:center;color:#714B67;">
                                    <strong>Nearby Connectivity</strong>
                                </h3>
                                <field name="connectivity_ids">
                                    <form>
                                        <group>
                                            <group>
                                                <field name="connectivity_id" required="1"/>
                                            </group>
                                            <group>
                                                <field name="distance" required="1"/>
                                            </group>
                                        </group>
                                    </form>
                                    <kanban>
                                        <field name="id"/>
                                        <field name="distance"/>
                                        <field name="image"/>
                                        <field name="connectivity_id"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click border-bottom rounded"
                                                     style="width: 343px; height: auto;border: 0px; border-bottom: none !important;">
                                                    <div style="text-align:center;">
                                                        <img alt="Avtar"
                                                             t-att-src="kanban_image('property.connectivity.line','image',record.id.raw_value)"
                                                             style="width:50px;height:50px;"/>
                                                    </div>
                                                    <br/>
                                                    <div style="text-align:center;">
                                                        <h6>
                                                            <field name="connectivity_id"/>
                                                        </h6>
                                                        <h2 style="color:#00A09D;">
                                                            <strong>
                                                                <field name="distance"/>
                                                            </strong>
                                                        </h2>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                            <page string="Documents">
                                <h3 style="color:#714B67;">
                                    <strong>Documents</strong>
                                </h3>
                                <field name="document_ids" widget="many2many" options="{'not_delete': True}">
                                    <kanban quick_create="true" create="true" delete="true">
                                        <field name="id"/>
                                        <field name="name"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click">
                                                    <div class="o_kanban_record_top">
                                                        <img t-att-src="kanban_image('documents.document', 'file', record.id.raw_value)"
                                                             height="40" t-att-alt="record.id.raw_value"
                                                             width="40"
                                                             class="oe_avatar oe_kanban_avatar_smallbox mb0"/>
                                                        <div class="o_kanban_record_headings ml8">

                                                            <strong class="o_kanban_record_title">
                                                                <field name="name"/>
                                                            </strong>
                                                        </div>
                                                        <a t-if="! read_only_mode" type="delete" class="text-danger">
                                                            <i class="fa fa-times" title="delete"></i>
                                                        </a>
                                                    </div>

                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>

                            <page string="Images">
                                <h3 style="color:#714B67;">
                                    <strong>Images</strong>
                                </h3>
                                <field name="property_images_ids">
                                    <form>
                                        <div class="oe_title float-left">
                                            <label for="title"/>
                                            <h1>
                                                <field name="title" required="1"/>
                                            </h1>
                                        </div>
                                        <div style="width:40%;height:40%;" class="float-right">
                                            <field name="image" style="width:40%;height:40%;"
                                                   class="img-thumbnail float-right" widget="image" required="1"/>
                                        </div>
                                    </form>
                                    <kanban>
                                        <field name="id"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click border-0"
                                                     style="width:333px;margin-top: -5px;margin-bottom: 0px;margin-right:-14px;">
                                                    <img alt="Avtar"
                                                         t-att-src="kanban_image('property.images','image',record.id.raw_value)"
                                                         style="width:30rem;height:20rem;" class="img-thumbnail"/>
                                                    <span style="font-size: 1.625rem;line-height: 1.625rem;min-height: 3.25rem;">
                                                        <center style="background-color: whitesmoke;">
                                                            <field name="title"/>
                                                        </center>
                                                    </span>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                            <page string="Amenities">
                                <h3 style="color:#714B67;">
                                    <strong>Amenities</strong>
                                </h3>
                                <field name="amenities_ids">
                                    <kanban>
                                        <field name="id"/>
                                        <field name="title"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click border-bottom rounded"
                                                     style="width:130px;height:60px;">
                                                    <div style="width:40%;float:left;display:inline-block;">
                                                        <img alt="Avtar"
                                                             t-att-src="kanban_image('property.amenities','image',record.id.raw_value)"
                                                             style="width:50px;height:40px;"/>
                                                    </div>
                                                    <div style="width:60%;float:right;display:inline-block;">
                                                        <h5 style="color:#714B67;">
                                                            <strong>
                                                                <field name="title"/>
                                                            </strong>
                                                        </h5>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                            <page string="Facilities">
                                <h3 style="color:#714B67;">
                                    <strong>Facilities</strong>
                                </h3>
                                <field name="property_specification_ids">
                                    <kanban>
                                        <field name="id"/>
                                        <field name="title"/>
                                        <field name="description_line1"/>
                                        <field name="description_line2"/>
                                        <field name="description_line3"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click border border-info border-bottom"
                                                     style="width:350px;min-height:100px;height:auto;">
                                                    <div style="width:40%;float:left;display:inline-block;">
                                                        <img alt="Avtar"
                                                             t-att-src="kanban_image('property.specification','image',record.id.raw_value)"
                                                             style="width:100px;height:100px;"
                                                             class="img-thumbnail-left"/>
                                                    </div>
                                                    <div style="width:60%;float:right;display:inline-block;">
                                                        <h4 style="color:#714B67;">
                                                            <strong>
                                                                <field name="title"/>
                                                            </strong>
                                                        </h4>
                                                        <h6>
                                                            <span>➸
                                                                <field name="description_line1"/>
                                                                <br/>➸
                                                                <field name="description_line2"/>
                                                                <br/>➸
                                                                <field name="description_line3"/>
                                                            </span>
                                                        </h6>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="parent_property_tree_view" model="ir.ui.view">
            <field name="name">parent.property.tree.view</field>
            <field name="model">parent.property</field>
            <field name="arch" type="xml">
                <list string="Property">
                    <field name="name"/>
                    <field name="landlord_id"/>
                </list>
            </field>
        </record>
        <record id="parent_property_search_view" model="ir.ui.view">
            <field name="name">parent.property.search.view</field>
            <field name="model">parent.property</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="landlord_id"/>
                </search>
            </field>
        </record>
        <record id="parent_property_action" model="ir.actions.act_window">
            <field name="name">Parent Property</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">parent.property</field>
            <field name="view_mode">list,form,search</field>
        </record>
    </data>
</odoo>