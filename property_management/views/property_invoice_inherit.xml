<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="property_invoice_form_inherit" model="ir.ui.view">
            <field name="name">property.invoice.form.inherit.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_reference']" position="before">
                    <field name="tenancy_id" invisible="1"/>

                    <field name="tenancy_property_id"/>
                    <field name="tenancy_parent_property_id" readonly="1" force_save="1"/>

                    <label for="invoice_period_to_date"/>
                    <div name="invoice_period_to_date" class="d-flex">
                        <field name="invoice_period_to_date"/>
                        <span class="oe_inline o_form_label mx-3">To</span>
                        <field name="invoice_period_from_date"/>
                    </div>

                    <field name="property_id" invisible="1"/>
                    <field name="sold_id" invisible="not sold_id" readonly="1"/>
                    <field name="sold_property_id" invisible="not sold_id" readonly="1"/>
                </xpath>
                <xpath expr="//button[@name='button_draft']" position="replace">
                    <button name="button_draft" string="Reset to Draft" type="object"
                            groups="account.group_account_invoice"
                            invisible="not show_reset_to_draft_button or payment_state in ['paid', 'in_payment', 'partial']"
                            data-hotkey="q"/>
                </xpath>
            </field>
        </record>

        <record id="property_invoice_tree_inherit" model="ir.ui.view">
            <field name="name">property.invoice.tree.inherit.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="before">
                    <field name="property_name" string="Property"/>
                </xpath>
                <xpath expr="//field[@name='invoice_date_due']" position="before">
                    <field name="invoice_period_to_date" string="Invoice From"/>
                    <field name="invoice_period_from_date" string="Invoice To"/>
                </xpath>
            </field>
        </record>

        <record id="account_move_search_inherit" model="ir.ui.view">
            <field name="name">account.move.search.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='salesperson']" position="before">
                    <filter name="property" string="Property" domain="[]"
                            context="{'group_by': 'tenancy_property_id'}"/>
                    <separator/>
                    <field name="tenancy_property_id"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>