<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Add property_manager_id to parent property form -->
  <record id="parent_property_manager_inherit" model="ir.ui.view">
    <field name="name">parent.property.form.manager.inherit</field>
    <field name="model">parent.property</field>
    <field name="inherit_id" ref="property_management.parent_property_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='maintenance_incharge_id']" position="after">
        <field name="property_manager_id"
               options="{'no_quick_create': True, 'no_create_edit': True}"
               help="The employee responsible for managing this building and all its units."/>
      </xpath>
    </field>
  </record>

  <!-- Show property manager on property details form (read-only, inherited) -->
  <record id="property_details_manager_inherit" model="ir.ui.view">
    <field name="name">property.details.form.manager.inherit</field>
    <field name="model">property.details</field>
    <field name="inherit_id" ref="property_management.property_details_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='pro_company_id']" position="after">
        <field name="property_manager_id" readonly="1"
               help="Assigned via the parent building. Change it on the Main Property record."/>
      </xpath>
    </field>
  </record>

  <!-- Show property manager on contract form (read-only) -->
  <record id="tenancy_manager_inherit" model="ir.ui.view">
    <field name="name">tenancy.details.form.manager.inherit</field>
    <field name="model">tenancy.details</field>
    <field name="inherit_id" ref="property_management.tenancy_details_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='pro_company_id']" position="after">
        <field name="property_manager_id" readonly="1"/>
      </xpath>
    </field>
  </record>

  <!-- Add property manager filter to key list views -->
  <record id="property_details_manager_filter" model="ir.ui.view">
    <field name="name">property.details.search.manager</field>
    <field name="model">property.details</field>
    <field name="inherit_id" ref="property_management.property_details_search_view"/>
    <field name="arch" type="xml">
      <xpath expr="//search" position="inside">
        <filter name="my_properties" string="My Properties"
                domain="[('property_manager_id', '=', uid)]"/>
        <group string="Group By">
          <filter name="group_by_manager" string="Property Manager"
                  context="{'group_by': 'property_manager_id'}"/>
        </group>
      </xpath>
    </field>
  </record>

  <!-- Landlord partner form — grant/revoke portal access -->
  <record id="landlord_portal_inherit" model="ir.ui.view">
    <field name="name">res.partner.landlord.portal.inherit</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="property_management.user_type_inherit_view"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="inside">
        <group string="Portal Access" invisible="not is_landlord">
          <field name="has_landlord_portal" widget="boolean_toggle"/>
          <button name="action_grant_landlord_portal" string="Grant Portal Access"
                  type="object" class="btn btn-outline-success"
                  invisible="has_landlord_portal or not is_landlord or not email"/>
          <button name="action_revoke_landlord_portal" string="Revoke Portal Access"
                  type="object" class="btn btn-outline-danger"
                  invisible="not has_landlord_portal"/>
        </group>
      </xpath>
    </field>
  </record>

</odoo>
