<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rent_invoice_form_view" model="ir.ui.view">
            <field name="name">rent.invoice.form.view</field>
            <field name="model">rent.invoice</field>
            <field name="arch" type="xml">
                <form create="false">
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="property_type" invisible="1"/>
                    <sheet>
                        <div class="oe_title">
                            <label for="tenancy_id"/>
                            <h1>
                                <field name="tenancy_id" required="1"
                                       options="{'no_quick_create':True,'no_create_edit':True}"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="customer_id" required="1"
                                       options="{'no_quick_create':True,'no_create_edit':True}"/>
                                <field name="property_id"/>
                                <field name="company_id" invisible="1"/>
                                <field name="landlord_id" invisible="1" force_save="1"/>
                                <field name="is_extra_service" invisible="1"/>
                            </group>
                            <group>
                                <label for="rent_invoice_id" class="mt-1"/>
                                <div name="rent_invoice_id">
                                    <field name="rent_invoice_id" readonly="1" class="oe_inline"
                                           force_save="1"
                                           style="width:auto;"/>
                                    <field name="payment_state" widget="badge"
                                           style="margin-left: 10px;width:auto;"
                                           decoration-success="payment_state=='paid'"
                                           decoration-danger="payment_state=='not_paid'"
                                           decoration-info="payment_state=='in_payment'"
                                           decoration-primary="payment_state=='partial'"
                                           decoration-warning="payment_state=='reversed'"
                                    />
                                </div>
                            </group>
                        </group>
                        <group string="Payment Information">
                            <group invisible="property_type != 'residential'">
                                <field name="type" required="1"/>
                                <field name="contract_type_name" invisible="1"/>
                                <label for="rent_month" string="Rent/Month"
                                       invisible="contract_type_name == 'service'"/>
                                <div name="rent_month" class="d-flex"
                                     invisible="contract_type_name == 'service'">
                                    <field name="rent_month" required="1" readonly="1"/>
                                </div>
                                <label for="rent_month" string="Service Charge/Month"
                                       invisible="contract_type_name != 'service'"/>
                                <div name="rent_month" class="d-flex"
                                     invisible="contract_type_name != 'service'">
                                    <field name="rent_month" required="1" readonly="1"/>
                                </div>
                                <field name="rent_amount" required="1" widget="monetary"
                                       invisible="1"/>

                                <label for="amount"
                                       invisible="contract_type_name == 'service'"
                                       string="Total Rent Amount"/>
                                <div invisible="contract_type_name == 'service'">
                                    <field name="amount" widget="monetary" required="1" readonly="1"
                                           force_save="1" string="Total Rent Amount"/>
                                </div>

                                <label for="amount" invisible="contract_type_name != 'service'"
                                       string="Total Service Charge"/>
                                <div invisible="contract_type_name != 'service'">
                                    <field name="amount" widget="monetary" required="1" readonly="1"
                                           force_save="1" string="Total Service Charge"/>
                                </div>
                            </group>
                            <group invisible="property_type == 'residential'">
                                <field name="type" required="1"/>
                                <field name="contract_type_name" invisible="1"/>
                                <label for="rent_month" string="Rent/Month"
                                       invisible="contract_type_name == 'service'"/>
                                <div name="rent_month" class="d-flex"
                                     invisible="contract_type_name == 'service'">
                                    <field name="rent_month" required="1" readonly="1"/>
                                </div>
                                <label for="rent_month" string="Service Charge/Month"
                                       invisible="contract_type_name != 'service'"/>
                                <div name="rent_month" class="d-flex"
                                     invisible="contract_type_name != 'service'">
                                    <field name="rent_month" required="1" readonly="1"/>
                                </div>
                                <field name="rent_amount" required="1" widget="monetary"
                                       invisible="1"/>

                                <label for="amount"
                                       invisible="contract_type_name == 'service'"
                                       string="Total Rent Amount"/>
                                <div invisible="contract_type_name == 'service'">
                                    <field name="amount" widget="monetary" required="1" readonly="1"
                                           force_save="1" string="Total Rent Amount"/>
                                </div>

                                <label for="amount"
                                       invisible="contract_type_name != 'service'"
                                       string="Total Service Charge"/>
                                <div invisible="contract_type_name != 'service'">
                                    <field name="amount" widget="monetary" required="1" readonly="1"
                                           force_save="1" string="Total Service Charge"/>
                                </div>
                            </group>
                            <group>
                                <field name="service_amount"
                                       invisible="not is_extra_service"
                                       readonly="1"/>
                                <field name="invoice_date" required="1" readonly="1" force_save="1"/>
                                <label for="invoice_period_to_date" string="Invoice Period"/>
                                <div name="invoice_period_to_date" class="d-flex">
                                    <field name="invoice_period_to_date"/>
                                    <span class="oe_inline o_form_label mx-3">To</span>
                                    <field name="invoice_period_from_date"/>
                                </div>
                                <field name="description"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="rent_invoice_tree_view" model="ir.ui.view">
            <field name="name">rent.invoice.tree.view</field>
            <field name="model">rent.invoice</field>
            <field name="arch" type="xml">
                <list string="Rent Invoice" create="false">
                    <header>
                        <button name="action_create_invoice" string="Create Invoice" class="btn-primary" type="object"/>
                    </header>
                    <field name="tenancy_id"/>
                    <field name="customer_id"/>
                    <field name="property_id"/>
                    <field name="tenancy_start_date"/>
                    <field name="tenancy_end_date"/>
                    <field name="invoice_date"/>
                    <field name="invoice_period_to_date" string="Invoice From"/>
                    <field name="invoice_period_from_date" string="Invoice To"/>
                    <field name="currency_id" column_invisible="1"/>
                    <field name="rent_month" string="Rent/Month"/>
                    <field name="rent_per_month" string="Rent/Month" column_invisible="1"/>
                    <field name="amount" string="Total Rent Amount"/>
                    <field name="rent_invoice_id" widget="many2onebutton"/>
                    <field name="payment_state" widget="badge"
                           decoration-success="payment_state=='paid'"
                           decoration-danger="payment_state=='not_paid'"
                           decoration-info="payment_state=='in_payment'"
                           decoration-primary="payment_state=='partial'"
                           decoration-warning="payment_state=='reversed'"
                    />
                </list>
            </field>
        </record>

        <record id="rent_invoice_calendar_view" model="ir.ui.view">
            <field name="name">rent.invoice.calendar.view</field>
            <field name="model">rent.invoice</field>
            <field name="arch" type="xml">
                <calendar string="Invoices" date_start="invoice_date" color="type" mode="month"
                          quick_create="False"
                          hide_time="True" event_open_popup="True">
                    <field name="tenancy_id"/>
                    <field name="customer_id"/>
                    <field name="type"/>
                    <field name="description"/>
                    <field name="rent_invoice_id" widget="many2onebutton"/>
                </calendar>
            </field>
        </record>
        <record id="rent_invoice_search_view" model="ir.ui.view">
            <field name="name">rent.invoice.search.view</field>
            <field name="model">rent.invoice</field>
            <field name="arch" type="xml">
                <search>
                    <field name="tenancy_id"/>
                    <field name="customer_id"/>
                    <field name="property_id"/>
                    <field name="parent_property_id"/>
                    <field name="invoice_date"/>
                    <field name="description"/>
                    <field name="rent_month" string="Rent/Month"/>
                    <field name="amount"/>
                    <field name="rent_invoice_id"/>
                    <separator/>
                    <group>
                        <filter string="Parent Property" name="parent_property" domain="[]"
                                context="{'group_by':'parent_property_id'}"/>
                        <filter string="Property" name="property" domain="[]"
                                context="{'group_by':'property_id'}"/>

                        <separator/>
                        <filter string="Customer" name="customer" domain="[]"
                                context="{'group_by':'customer_id'}"/>
                        <separator/>
                        <filter string="Landlord" name="landlord" domain="[]"
                                context="{'group_by':'landlord_id'}"/>
                        <separator/>
                        <filter string="Payment" name="payment" domain="[]"
                                context="{'group_by':'type'}"/>
                        <separator/>
                        <filter string="Payment Status" name="payment_status" domain="[]"
                                context="{'group_by':'payment_state'}"/>
                        <separator/>
                        <filter string="Invoice" name="invoice" domain="[]"
                                context="{'group_by':'rent_invoice_id'}"/>
                        <separator/>
                        <filter string="Start Date" name="start_date" domain="[]"
                                context="{'group_by':'invoice_period_to_date'}"/>
                        <filter string="End Date" name="end_date" domain="[]"
                                context="{'group_by':'invoice_period_from_date'}"/>
                    </group>
                    <filter string="Not Paid" name="not_paid" domain="[('payment_state', '=', 'not_paid')]"/>
                    <filter string="In Payment" name="in_payment" domain="[('payment_state', '=', 'in_payment')]"/>
                    <filter string="Paid" name="paid" domain="[('payment_state', '=', 'paid')]"/>
                    <filter string="Partially Paid" name="partial" domain="[('payment_state', '=', 'partial')]"/>
                    <filter string="Reversed" name="reversed" domain="[('payment_state', '=', 'reversed')]"/>
                    <filter string="Invoicing App Legacy" name="invoicing_legacy"
                            domain="[('payment_state', '=', 'invoicing_legacy')]"/>
                    <separator/>
                    <filter string="Invoiced" name="invoiced" domain="[('rent_invoice_id', '!=', False)]"/>
                    <filter string="Not Invoiced" name="not_invoiced" domain="[('rent_invoice_id', '=', False)]"/>
                    <separator/>
                    <filter string="Start Date" name="start_date" domain="[]" date="invoice_period_to_date"/>
                    <filter string="End Date" name="end_date" domain="[]" date="invoice_period_from_date"/>
                    <separator/>
                    <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record id="rent_invoice_pivot_view" model="ir.ui.view">
            <field name="name">rent.invoice.pivot.view</field>
            <field name="model">rent.invoice</field>
            <field name="arch" type="xml">
                <pivot string="Statistic">
                    <field name="tenancy_id" type="row"/>
                    <field name="amount" type="measure" string="Total Rent Amount"/>
                    <field name="service_charge_month" string="Service Charge"/>
                    <field name="rent_month" string="Rent/Month" type="measure"/>
                    <field name="invoice_date" type="col" interval="month"/>
                    <field name="type" type="col"/>
                </pivot>
            </field>
        </record>

        <record id="rent_invoice_action" model="ir.actions.act_window">
            <field name="name">Rent Invoice</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">rent.invoice</field>
            <field name="view_mode">list,form,calendar,pivot,activity</field>
            <field name="context">{}</field>
        </record>
    </data>
</odoo>