<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="agreement_template_preview_wizard_view_form" model="ir.ui.view">
        <field name="name">agreement.template.preview.wizard.view.form</field>
        <field name="model">template.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Preview Agreement Template">
                <sheet>
                    <div colspan="2">
                        <field name="agreement_body" no_label="1"/>
                    </div>
                    <field name="agreement_template_id" invisible="1"/>
                </sheet>
                <footer>
                    <button name="cancel" special="cancel" data-hotkey="z" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="agreement_template_preview_action" model="ir.actions.act_window">
        <field name="name">Agreement Template Preview</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">template.preview.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_agreement_template_id': active_id}</field>
    </record>
</odoo>