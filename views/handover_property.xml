<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="handover_property_details_form_view" model="ir.ui.view">
            <field name="name">handover.property.form.view</field>
            <field name="model">handover.property</field>
            <field name="arch" type="xml">
                <form string="Handover Property" create="false">
                    <header>
                        <button name="print_handover_detials" type='object' string="Print Handover Property Details" class="btn btn-outline-dark"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="handover_seq"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date" required="1"/>
                                <field name="property_id" required="1"/>
                                <field name="main_property_id" required="1"/>
                                <field name="tenant_id" required="1"/>
                                <field name="electric_reading" required="1"/>
                                <field name="generator_reading" required="1"/>
                                <field name="inspection_report"/>
                            </group>
                            <group></group>
                        </group>

                        <group string="Handover Details">
                            <group>
                                <field name="no_of_key"/>
                                <field name="barrier_card"/>
                                <field name="barrier_card_no"/>
                            </group>
                            <group>
                                <field name="access_card"/>
                                <field name="access_card_no"/>
                                <field name="file_name" invisible="1"/>
                                <field name="signed_form" filename="file_name" widget="binary"/>
                            </group>
                        </group>

                        <group string="Property Assets">
                        </group>
                        <field name="assets_ids" nolabel="1" widget="section_and_note_one2many" mode="list" readonly="1">
                            <list editable="bottom">
                                <control>
                                    <create name="add_product_control" string="Add a line"/>
                                    <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                </control>

                                <field name="display_type" column_invisible="1"/>
                                <field name="serial_no"/>
                                <field name="product_id"/>
                                <field name="name" widget="section_and_note_text" optional="show"/>
                                <field name="Prod_qty"/>
                                <field name="prod_condition"/>
                                <field name="remark"/>
                            </list>
                        </field>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="handover_property_details_tree_view" model="ir.ui.view">
            <field name="name">handover.property.tree.view</field>
            <field name="model">handover.property</field>
            <field name="arch" type="xml">
                <list string="Handover Property" create="false">
                    <field name="handover_seq"/>
                    <field name="property_id"/>
                    <field name="main_property_id"/>
                    <field name="tenant_id"/>
                    <field name="electric_reading"/>
                    <field name="generator_reading"/>
                </list>
            </field>
        </record>


        <record id="handover_kanban_view" model="ir.ui.view">
            <field name="name">handover.property.kanban.view</field>
            <field name="model">handover.property</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" sample="1">
                    <field name="handover_seq"/>
                    <field name="date"/>
                    <field name="property_id"/>
                    <field name="tenant_id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="row mb4">
                                    <div class="col-6 o_kanban_record_headings">
                                        <strong>
                                            <span>
                                                <field name="handover_seq"/>
                                            </span>
                                        </strong><br/>
                                        <field name="date"/><br/>
                                    </div>
                                    
                                </div>
                                <div class="row">
                                    <div class="col-12">
                                        <span>
                                            <field name="property_id"/>
                                            <field name="tenant_id"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="handover_search_view" model="ir.ui.view">
            <field name="name">handover.search.view</field>
            <field name="model">handover.property</field>
            <field name="arch" type="xml">
                <search>
                    <filter string="Property" name="property_id" domain="[]" context="{'group_by':'property_id'}"/>
                    <separator/>
                </search>
            </field>
        </record>

        <record id="handover_property_details_action" model="ir.actions.act_window">
            <field name="name">Handover Property</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">handover.property</field>
            <field name="view_mode">list,form,kanban</field>
        </record>
    </data>
</odoo>