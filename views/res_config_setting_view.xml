<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_rental" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.rental</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Real Estate" id="real_estate" string="Real Estate"
                         name="real_estate" logo="rental_management/static/description/icon.png">
                        <block title="Reminder Days" id="reminder_days">
                            <setting
                                    help="Reminder days for Creating Invoice">
                                <field name="reminder_days" class="ms-2 oe_inline"
                                       style="width: 10%; min-width: 4rem;" string="Tenancy Reminder Days"/>
                            </setting>
                            <setting
                                    help="Reminder days for Creating Invoice">
                                <field name="sale_reminder_days" class="ms-2 oe_inline"
                                       style="width: 10%; min-width: 4rem;" string="Sale Reminder Days"/>
                            </setting>
                        </block>
                        <block title="Property Reports">
                            <setting help="The entered emails will get property report mail">
                                <field name="property_report_mails"/>
                            </setting>
                        </block>
                        <block title="Sender Email">
                            <setting help="Enter sender email for alert mails">
                                <field name="alert_mail_sender_email" required="1"/>
                            </setting>
                        </block>
                        <block title="Utility Bills">
                            <setting help="Select template to send whatsapp on confirming utility bill">
                                <field name="utility_bill_wh_template_id"/>
                            </setting>
                            <setting help="Select template to send whatsapp on utility bill payment registration">
                                <field name="payment_receipt_wh_template_id"/>
                            </setting>
                        </block>
                        <block title="Bank Details" help="Used in lease agreement reports. CRDB BANK (T) LTD is set as default.">
                            <setting help="Bank name shown on lease agreement payment clause">
                                <field name="bank_name" string="Bank Name" placeholder="e.g. CRDB BANK (T) LTD"/>
                            </setting>
                            <setting help="USD bank account number for rent payments">
                                <field name="bank_account_usd" string="USD Account No."/>
                            </setting>
                            <setting help="TZS bank account number for rent payments">
                                <field name="bank_account_tzs" string="TZS Account No."/>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

