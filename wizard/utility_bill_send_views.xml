<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="utility_bill_send_wizard_form" model="ir.ui.view">
            <field name="name">utility.bill.send.form</field>
            <field name="model">utility.bill.send</field>
            <field name="groups_id" eval="[(4,ref('base.group_user'))]"/>
            <field name="arch" type="xml">
                <form string="Bill send &amp; Print">
                    <field name="composition_mode" invisible="1"/>
                    <field name="bill_ids" invisible="1"/>
                    <field name="email_from" invisible="1"/>
                    <field name="mail_server_id" invisible="1"/>
                    <div name="option_print">
                        <field name="is_print"/>
                        <b>
                            <label for="is_print"/>
                        </b>
                        <div name="info_form"
                             invisible="not is_print or composition_mode == 'mass_mail'"
                             class="text-center text-muted d-inline-block ms-2">
                            Preview as a PDF
                        </div>
                    </div>
                    <div name="option_email">
                        <field name="is_email"/>
                        <b>
                            <label for="is_email"/>
                        </b>
                    </div>
                    <div class="text-start d-inline-block mr8"
                         invisible="not is_email or not bill_without_email">
                        <field name="bill_without_email" class="mr4"/>
                    </div>
                    <div name="mail_form" invisible="not is_email">
                        <!-- visible wizard -->
                        <div invisible="composition_mode == 'mass_mail'">
                            <group>
                                <label for="partner_ids" string="Recipients" groups="base.group_user"/>
                                <div groups="base.group_user">
                                    <span invisible="composition_mode != 'mass_mail'">
                                        <strong>Email mass mailing</strong>
                                        on
                                        <span>the selected records</span>
                                    </span>
                                    <span>Followers of the document and</span>
                                    <field name="partner_ids" widget="many2many_tags_email"
                                           placeholder="Add contacts to notify..."
                                           context="{'force_email':True, 'show_email':True}"
                                           invisible="composition_mode == 'mass_mail'"/>
                                </div>
                                <field name="subject" placeholder="Subject..."
                                       required="is_email and composition_mode == 'comment'"/>
                            </group>
                            <field name="body" class="oe-bordered-editor" options="{'style-inline': true}"/>
                        </div>
                        <group>
                            <group invisible="composition_mode == 'mass_mail'">
                                <field name="attachment_ids" widget="many2many_binary" string="Attach a file"
                                       nolabel="1" colspan="2"
                                       invisible="composition_mode == 'mass_mail'"/>
                            </group>
                            <group>
                                <field name="template_id" options="{'no_create': True, 'no_edit': True}"
                                       context="{'default_model': 'account.move'}"/>
                            </group>
                        </group>
                    </div>

                    <footer>
                        <button string="Send &amp; Print"
                                invisible="not is_email or not is_print"
                                data-hotkey="q"
                                name="send_and_print_action" type="object"
                                class="send_and_print btn-primary o_mail_send"/>
                        <button string="Send" data-hotkey="q"
                                invisible="is_print or not is_email"
                                name="send_and_print_action" type="object" class="send btn-primary o_mail_send"/>
                        <button string="Print" data-hotkey="q"
                                invisible="not is_print or is_email"
                                name="send_and_print_action" type="object" class="print btn-primary o_mail_send"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="bill_send" model="ir.actions.server">
            <field name="name">Send &amp; print</field>
            <field name="state">code</field>
            <field name="type">ir.actions.server</field>
            <field name="model_id" ref="model_utility_bill"/>
            <field name="binding_model_id" ref="model_utility_bill"/>
            <field name="binding_view_types">list</field>
            <field name="code">
                if records:
                action = records.action_send_and_print()
            </field>
        </record>

    </data>

</odoo>
